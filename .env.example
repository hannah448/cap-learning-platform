# =============================================================
# Cap Learning — Billing integration environment variables
# =============================================================
# Copy this file to `.env.local` (for local dev) and add the real
# values in your Vercel dashboard (Settings > Environment Variables)
# for production.
#
# NEVER commit .env.local — it's gitignored.
# =============================================================

# --- Public ---
# Public-facing base URL of your deployed site. Used as prefix for
# return_url and notify_url in CinetPay requests.
PUBLIC_BASE_URL=https://caplearning.com

# --- CinetPay ---
# Get these from your CinetPay dashboard:
#   https://app.cinetpay.com/ → Intégration → Mes identifiants API
CINETPAY_API_KEY=__your_cinetpay_api_key__
CINETPAY_SITE_ID=__your_cinetpay_site_id__
# Used to verify webhook signatures (HMAC-SHA256)
CINETPAY_SECRET_KEY=__your_cinetpay_secret_key__

# --- Pennylane ---
# Generate an API key in your Pennylane account:
#   Settings > Integrations > API > Create new token
# Requires Pro or Premium plan.
PENNYLANE_API_KEY=__your_pennylane_api_key__
# Optional: code of the sales journal to record payments against.
# Defaults to 'VE' (Ventes). Check yours in Pennylane > Comptabilité > Journaux.
PENNYLANE_JOURNAL=VE
