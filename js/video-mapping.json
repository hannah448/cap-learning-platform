{
  "_doc": {
    "purpose": "Mapping central entre chaque leçon de apprendre.html et sa source vidéo. Rempli au fur et à mesure des uploads Vimeo (ou S3 plus tard).",
    "lookup_key": "lesson_id (ex: 'l1-1', 'e2-1', 'i1-2') — doit matcher exactement l'id dans pages/apprendre.html",
    "how_to_fill_vimeo": [
      "1. Upload la vidéo sur Vimeo (compte Plus ou Pro)",
      "2. Privacy > Hide from Vimeo + Only embed on caplearning.com",
      "3. Copier l'URL embed, ex: https://player.vimeo.com/video/987654321?h=abc123def4",
      "4. Remplir 'id' = 987654321 et 'hash' = abc123def4 dans l'entrée correspondante ci-dessous",
      "5. Mettre 'status' = 'live' (au lieu de 'pending')",
      "6. Commit + push → Vercel redéploie automatiquement"
    ],
    "how_to_fill_s3": [
      "1. Encoder la vidéo en HLS via AWS MediaConvert (bitrates 240p/480p/720p/1080p)",
      "2. Uploader le dossier HLS sur S3 bucket privé caplearning-videos",
      "3. Noter l'URL CloudFront de master.m3u8 (ex: https://d1abc.cloudfront.net/lessons/l1-1/master.m3u8)",
      "4. Remplacer le bloc video.vimeo par video.s3 et remplir l'URL",
      "5. Le player (js/video-player.js) détecte automatiquement le provider et charge hls.js"
    ],
    "schema_version": 1,
    "last_updated": null
  },

  "_defaults": {
    "provider": "vimeo",
    "privacy_mode": "domain_restricted",
    "allowed_domains": ["caplearning.com", "www.caplearning.com", "caplearning.vercel.app"]
  },

  "_example_filled_entry": {
    "l1-1": {
      "title": "Introduction au marketing digital en Afrique",
      "status": "live",
      "provider": "vimeo",
      "vimeo": {
        "id": "987654321",
        "hash": "abc123def4"
      },
      "duration_seconds": 750,
      "poster": null,
      "subtitles": [
        { "lang": "fr", "label": "Français", "default": true }
      ],
      "notes": "Exemple rempli — à recopier ensuite pour chaque leçon."
    }
  },

