{
  "Version": "2012-10-17",
  "Id": "CapLearningVideosPolicy",
  "Statement": [
    {
      "Sid": "AllowCloudflareWarpIps",
      "Effect": "Allow",
      "Principal": "*",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::caplearning-videos/cap-learning/videos/*",
      "Condition": {
        "IpAddress": {
          "aws:SourceIp": [
            "103.21.244.0/22",
            "103.22.200.0/22",
            "103.31.4.0/22",
            "104.16.0.0/13",
            "104.24.0.0/14",
            "108.162.192.0/18",
            "131.0.72.0/22",
            "141.101.64.0/18",
            "162.158.0.0/15",
            "172.64.0.0/13",
            "173.245.48.0/20",
            "188.114.96.0/20",
            "190.93.240.0/20",
            "197.234.240.0/22",
            "198.41.128.0/17"
          ]
        }
      }
    }
  ],
  "_comment": "Seuls les IPs Cloudflare peuvent GET les objets. L'accès direct au bucket S3 depuis un navigateur utilisateur est bloqué (hotlink protection). Met à jour la liste d'IP depuis https://www.cloudflare.com/ips-v4 (et ips-v6) — Cloudflare change la liste ~1x/an."
}
